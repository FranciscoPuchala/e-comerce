rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Orders: anyone can create (checkout), only authenticated admins can read/update.
    match /orders/{orderId} {
      allow create: if
        request.resource.data.keys().hasAll(['customer', 'items', 'total', 'status']) &&
        request.resource.data.total is number &&
        request.resource.data.total > 0;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

    // Newsletter: anyone can subscribe, only admins can read.
    match /newsletter/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['email']) &&
        request.resource.data.email is string;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Contacts: anyone can create (contact form), only authenticated admins can read/update.
    match /contacts/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message']) &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.message.size() >= 10;
      allow read, update: if request.auth != null;
      allow delete: if false;
    }

  }
}
