rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Orders: cualquiera puede crear, nadie puede leer/editar desde el cliente.
    match /orders/{orderId} {
      allow create: if
        request.resource.data.keys().hasAll(['customer', 'items', 'total', 'status']) &&
        request.resource.data.total is number &&
        request.resource.data.total > 0;
      allow read, update, delete: if false;
    }

    // Contacts: anyone can create (submit form), nobody can read from client.
    match /contacts/{docId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'subject', 'message']) &&
        request.resource.data.name is string &&
        request.resource.data.email is string &&
        request.resource.data.message.size() >= 10;
      allow read, update, delete: if false;
    }

  }
}
